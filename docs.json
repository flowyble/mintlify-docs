{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flowyble Documentation",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "concepts"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/overview",
              "agents/configuration",
              "agents/execution",
              "agents/conversations"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/overview",
              "tools/built-in-functions",
              "tools/custom-tools"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/oauth2",
              "integrations/webhooks"
            ]
          },
          {
            "group": "Billing & Credits",
            "pages": [
              "billing/credits",
              "billing/plans"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "api-reference/agents/run-agent",
              "api-reference/agents/get-run-status",
              "api-reference/agents/get-run-details"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "api-reference/tools/run-tool",
              "api-reference/tools/get-run-status",
              "api-reference/tools/get-run-result"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/incoming"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "terminal"
        },
        {
          "anchor": "Changelog",
          "href": "https://flowyble.com/changelog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@flowyble.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.flowyble.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/flowyble",
      "linkedin": "https://linkedin.com/company/flowyble"
    }
  },
  "background": {
    "color": {
      "light": "#e9ecef",
      "dark": "#0d0b14"
    }
  },
  "appearance": {
    "default": "system"
  },
  "logo": "/images/120x120.png"
}
